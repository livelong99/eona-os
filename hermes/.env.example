# Agent Home — Hermes secrets (TEMPLATE) → copy to hermes/.env (gitignored).
# The ONLY paid credential is your Gemini key. Claude uses the Claude Code CLI
# subscription (no key here). Ollama/SearXNG/Crawl4AI/Qdrant need no keys.
# NEVER commit hermes/.env. NEVER put secrets in the Obsidian vault.

# Gemini key. Set BOTH names: GEMINI_API_KEY for native detection, and
# OPENAI_API_KEY (same value) because the OpenAI-compatible endpoint in
# config.yaml authenticates with OPENAI_API_KEY.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Shared memory — Obsidian Local REST API plugin token (Bearer prefix stripped)
MCP_OBSIDIAN_API_KEY=

# Claude Code delegation bridge — shared local token (not a paid cred).
# Generate: openssl rand -hex 16 . Start the host bridge with BRIDGE_TOKEN set to
# this same value: BRIDGE_TOKEN=$CLAUDE_BRIDGE_TOKEN python3 scripts/claude-bridge.py
CLAUDE_BRIDGE_TOKEN=
