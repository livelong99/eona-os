# Agent Home — Hermes secrets (TEMPLATE) → copy to ~/.hermes/.env
# NEVER commit the real ~/.hermes/.env. NEVER put these in the Obsidian vault.
# Tier D (Claude) uses the Claude Code CLI subscription — no key needed here.

# Tier C — Gemini (Google AI Studio key) — REQUIRED for v1
GEMINI_API_KEY=

# Tier B — free cloud (optional; NON-SENSITIVE use only — these log prompts)
OPENROUTER_API_KEY=
ZAI_API_KEY=

# Shared memory — Obsidian Local REST API plugin token (Bearer prefix stripped)
MCP_OBSIDIAN_API_KEY=

# Tier A — Ollama/LM Studio: no key (local endpoint http://127.0.0.1:11434)
