{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-home/schemas/brainstorm_qna.schema.json",
  "title": "Brainstorm clarifying Q&A (qna.json)",
  "description": "Structured clarifying questions written by the Sage PM agent and rendered by the dashboard QnAView. The user fills answers; the agent re-reads this file each round.",
  "type": "object",
  "required": ["project", "slug", "phase", "questions"],
  "additionalProperties": true,
  "properties": {
    "project": { "type": "string" },
    "slug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "brief": { "type": "string" },
    "phase": { "type": "string", "enum": ["clarifying", "prd-ready"] },
    "round": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string" },
    "open_count": { "type": "integer", "minimum": 0 },
    "answered_count": { "type": "integer", "minimum": 0 },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "question", "answered"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "agent": { "type": "string", "description": "Specialist that raised this question (Creativity|Feasibility|Reliability|Roadmap|PM)." },
          "category": { "type": "string" },
          "question": { "type": "string" },
          "why": { "type": "string", "description": "Why this question matters / what metric it unblocks." },
          "answer": { "type": "string" },
          "answered": { "type": "boolean" },
          "round": { "type": "integer", "minimum": 1 }
        }
      }
    }
  }
}
